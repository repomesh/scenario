{
  "name": "realtime-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.5.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "realtime-server": "dotenv -e .env pnpm exec tsx src/server/start-server.ts",
    "realtime-tunnel": "cloudflared tunnel --url=http://localhost:5173",
    "start": "dotenv -e .env concurrently -n server,client -c blue,magenta \"pnpm realtime-server\" \"pnpm dev\"",
    "start:full": "dotenv -e .env concurrently -n server,client,tunnel -c blue,magenta,cyan \"pnpm realtime-server\" \"pnpm dev\" \"pnpm realtime-tunnel\""
  },
  "dependencies": {
    "@langwatch/scenario": "workspace:*",
    "@radix-ui/react-slot": "1.2.4",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.4.0",
    "@tailwindcss/vite": "4.1.17",
    "@types/three": "0.181.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.17",
    "three": "0.181.2",
    "use-stick-to-bottom": "1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tw-animate-css": "1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4"
  }
}
