{
  "name": "scenario-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf docs/dist",
    "generate:mdx-examples": "node scripts/generate-mdx-examples.js",
    "dev": "pnpm generate:mdx-examples && vocs dev",
    "build": "pnpm generate:mdx-examples && vocs build",
    "preview": "vocs preview",
    "build:preview": "pnpm build && vocs preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "eslint . --fix"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.17",
    "lucide-react": "^0.555.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router": "^7.9.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "vocs": "github:langwatch/vocs#build",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "latest",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-mdx": "^3.6.2",
    "eslint-plugin-mdx": "^3.6.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.7.1",
    "typescript": "latest",
    "typescript-eslint": "^8.48.0",
    "vite-plugin-sitemap": "^0.8.2"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.4",
      "lodash-es": ">=4.17.21",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "flatted@<3.4.2": ">=3.4.2",
      "react-router@>=7.0.0 <7.12.0": ">=7.12.0"
    }
  }
}
