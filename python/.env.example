OPENAI_API_KEY=
# LANGWATCH_ENDPOINT=https://app.langwatch.ai - this is the default
LANGWATCH_API_KEY="your-api-key"

# Voice e2e tests (issue #350)
# Twilio — required for TwilioAgentAdapter tests. Both TWILIO_PHONE_NUMBER
# and TWILIO_PHONE_NUMBER_2 are Twilio-owned numbers you control; inbound/
# outbound demos dial between them so no human is required.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_PHONE_NUMBER_2=
# ElevenLabs — required for ElevenLabsAgentAdapter (hosted) and ElevenLabsSTTProvider
ELEVENLABS_API_KEY=
# ElevenLabs hosted agent ID — created by `scripts/provision_elevenlabs_agent.py`
# Run: uv run python scripts/provision_elevenlabs_agent.py
ELEVENLABS_AGENT_ID=
# Gemini — required for GeminiLiveAgentAdapter
GEMINI_API_KEY=
# Override the default Pipecat bot WebSocket URL (default: ws://localhost:8765/stream)
PIPECAT_BOT_URL=ws://localhost:8765/stream

# Logging — runs automatically append to recordings/scenario.log alongside
# audio artifacts. The file captures the scenario logger at SCENARIO_LOG_LEVEL
# AND third-party warnings/errors (litellm, OpenAI, OpenTelemetry, Pipecat)
# so failures have a full paper trail. The recordings/ dir is gitignored.
SCENARIO_LOG_LEVEL=debug
SCENARIO_LOG_FILE=recordings/scenario.log
