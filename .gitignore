# Python voice demo outputs (recordings + manifests). Most are regenerated
# per local run, NOT committed. But the subset listed below is checked in as
# PR evidence: each demo's `full.wav`, `manifest.json`, and for the core
# provider demos the per-turn `segments/` directory are the canonical
# "prove it" artifacts for reviewers. See python/outputs/README.md (parent
# index) and python/outputs/recordings/README.md (audio policy).
#
# Shape: outputs/ is the artifact parent (room for traces/, logs/,
# screenshots/ later). recordings/ is the audio subdir, and only it is
# whitelisted today; new artifact siblings will get their own block when added.
python/outputs/*
!python/outputs/README.md
!python/outputs/recordings/
python/outputs/recordings/*
!python/outputs/recordings/README.md
# Core provider demos: commit full.wav + manifest.json + per-turn segments/.
!python/outputs/recordings/elevenlabs_hosted/
!python/outputs/recordings/elevenlabs_branded/
!python/outputs/recordings/elevenlabs_interruption/
!python/outputs/recordings/twilio_inbound/
!python/outputs/recordings/twilio_outbound/
!python/outputs/recordings/gemini_live/
!python/outputs/recordings/gemini_live_interruption/
# Additional demos — commit only full.wav + manifest.json (skip segments/
# to avoid hundreds of tiny per-turn wavs in the tree).
!python/outputs/recordings/openai_realtime_agent/
python/outputs/recordings/openai_realtime_agent/segments/
!python/outputs/recordings/pipecat_scenario/
python/outputs/recordings/pipecat_scenario/segments/
!python/outputs/recordings/pipecat_ws/
python/outputs/recordings/pipecat_ws/segments/
!python/outputs/recordings/basic_greeting/
python/outputs/recordings/basic_greeting/segments/
!python/outputs/recordings/voice_text_parity/
python/outputs/recordings/voice_text_parity/segments/
!python/outputs/recordings/recording_playback/
python/outputs/recordings/recording_playback/segments/
!python/outputs/recordings/interruption_recovery/
python/outputs/recordings/interruption_recovery/segments/
!python/outputs/recordings/random_interruptions/
python/outputs/recordings/random_interruptions/segments/
!python/outputs/recordings/angry_customer/
python/outputs/recordings/angry_customer/segments/
!python/outputs/recordings/background_handoff/
python/outputs/recordings/background_handoff/segments/
!python/outputs/recordings/stt_swap/
python/outputs/recordings/stt_swap/segments/

# TypeScript voice demo outputs (recordings + manifests) — same policy as
# python/outputs/recordings/ above. Regenerated per local run by the @e2e demo tests
# under javascript/examples/vitest/tests/voice/; the committed subset below
# is the canonical "prove it" audio evidence. See
# javascript/examples/vitest/outputs/README.md (parent index) and
# javascript/examples/vitest/outputs/recordings/README.md (audio policy).
#
# Shape: outputs/ is the artifact parent (room for traces/, logs/,
# screenshots/ later). recordings/ is the audio subdir — only it is
# whitelisted today; new artifact siblings will get their own block when added.
javascript/examples/vitest/outputs/*
!javascript/examples/vitest/outputs/README.md
!javascript/examples/vitest/outputs/recordings/
javascript/examples/vitest/outputs/recordings/*
!javascript/examples/vitest/outputs/recordings/README.md
# Core demos — commit full.wav + manifest.json + per-turn segments/.
!javascript/examples/vitest/outputs/recordings/openai_realtime_agent/
!javascript/examples/vitest/outputs/recordings/openai_realtime_user/
!javascript/examples/vitest/outputs/recordings/elevenlabs_hosted/
!javascript/examples/vitest/outputs/recordings/elevenlabs_branded/
!javascript/examples/vitest/outputs/recordings/gemini_live/
# Additional demos — commit only full.wav + manifest.json (skip segments/
# to keep the tree thin, mirroring the Python additional-demo policy).
!javascript/examples/vitest/outputs/recordings/composable_stt_swap/
javascript/examples/vitest/outputs/recordings/composable_stt_swap/segments/
!javascript/examples/vitest/outputs/recordings/recording_playback/
javascript/examples/vitest/outputs/recordings/recording_playback/segments/
!javascript/examples/vitest/outputs/recordings/voice_text_parity/
javascript/examples/vitest/outputs/recordings/voice_text_parity/segments/
!javascript/examples/vitest/outputs/recordings/pipecat_ws/
javascript/examples/vitest/outputs/recordings/pipecat_ws/segments/
# Interruption demos — the flagship voice capability. Per-adapter interruption
# demos (EL / Gemini) commit segments (match python/recordings); the
# script-driven ones commit full.wav + manifest only.
!javascript/examples/vitest/outputs/recordings/interruption_recovery/
javascript/examples/vitest/outputs/recordings/interruption_recovery/segments/
!javascript/examples/vitest/outputs/recordings/random_interruptions/
javascript/examples/vitest/outputs/recordings/random_interruptions/segments/
!javascript/examples/vitest/outputs/recordings/elevenlabs_interruption/
# gemini_live_interruption: full.wav (8kHz) + manifest only — Gemini's detailed
# replies make individual segment WAVs exceed the 1MB cap.
!javascript/examples/vitest/outputs/recordings/gemini_live_interruption/
javascript/examples/vitest/outputs/recordings/gemini_live_interruption/segments/
# Persona / pain-pattern + greeting + pipecat-scenario demos — full.wav +
# manifest only (additional-demo policy).
!javascript/examples/vitest/outputs/recordings/basic_greeting/
javascript/examples/vitest/outputs/recordings/basic_greeting/segments/
!javascript/examples/vitest/outputs/recordings/angry_customer/
javascript/examples/vitest/outputs/recordings/angry_customer/segments/
!javascript/examples/vitest/outputs/recordings/background_handoff/
javascript/examples/vitest/outputs/recordings/background_handoff/segments/
!javascript/examples/vitest/outputs/recordings/pipecat_scenario/
javascript/examples/vitest/outputs/recordings/pipecat_scenario/segments/
